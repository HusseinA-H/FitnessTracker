# ==============================================================
# FitnessTracker Backend — Environment Template
# Copy this file to .env and fill in real values
# ==============================================================

# Django Environment (local | staging | production)
DJANGO_ENV=local

# Security Configuration
SECRET_KEY=replace_this_with_a_long_random_secret_key_in_production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Configuration (Enforced for all environments)
DB_NAME=fitnesstracker_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=127.0.0.1
DB_PORT=5432

# CORS Configurations
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# CSRF Trusted Origins (must match frontend origins for cross-origin POST requests)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT Configuration (SimpleJWT Settings)
JWT_SECRET_KEY=replace_this_with_another_long_random_jwt_signing_key
JWT_ACCESS_LIFETIME_MINUTES=15
JWT_REFRESH_LIFETIME_DAYS=7

# Admin Bootstrap Configuration (used by create_admin management command)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@fitnesstracker.local
ADMIN_PASSWORD=replace_this_with_a_secure_password

# Groq AI Configuration
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile