# ==============================================================
# FitnessTracker — Root .env template for Docker Compose
# Copy to .env and fill in real values for production
# ==============================================================

# PostgreSQL
DB_NAME=fitnesstracker_db
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_use_a_strong_db_password

# Frontend build arg — relative URL for Docker reverse proxy
VITE_API_BASE_URL=/api/v1